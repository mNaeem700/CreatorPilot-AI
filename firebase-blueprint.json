{
  "entities": {
    "users": {
      "title": "UserProfile",
      "description": "Stores user profiles, subscriptions, and current credit balances",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user identifier from Auth"
        },
        "email": {
          "type": "string",
          "description": "Primary verified email address"
        },
        "displayName": {
          "type": "string",
          "description": "User full name"
        },
        "photoURL": {
          "type": "string",
          "description": "Avatar image URL"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "Access privileges within the system"
        },
        "plan": {
          "type": "string",
          "enum": ["free", "starter", "creator", "agency"],
          "description": "Subscription tier level"
        },
        "credits": {
          "type": "integer",
          "description": "Available credits to run AI tools"
        },
        "maxCredits": {
          "type": "integer",
          "description": "Maximum monthly credits for current plan"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date of registration"
        }
      },
      "required": ["uid", "email", "displayName", "role", "plan", "credits", "maxCredits", "createdAt"]
    },
    "history": {
      "title": "HistoryEntry",
      "description": "Past AI generation outputs associated with a user",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique generation ID"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the history entry"
        },
        "toolId": {
          "type": "string",
          "description": "Identifies which AI tool produced this"
        },
        "toolName": {
          "type": "string",
          "description": "Display name of the tool"
        },
        "inputs": {
          "type": "object",
          "description": "Key-value map of form inputs used"
        },
        "output": {
          "type": "string",
          "description": "AI-generated text response"
        },
        "isFavorite": {
          "type": "boolean",
          "description": "Flag indicating if user favorited this"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date and time generated"
        }
      },
      "required": ["id", "userId", "toolId", "toolName", "inputs", "output", "isFavorite", "createdAt"]
    },
    "tickets": {
      "title": "SupportTicket",
      "description": "Support inquiries created by users",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Ticket ID"
        },
        "userId": {
          "type": "string",
          "description": "ID of creator user"
        },
        "userEmail": {
          "type": "string",
          "description": "Email of user for communications"
        },
        "subject": {
          "type": "string",
          "description": "Title of ticket"
        },
        "message": {
          "type": "string",
          "description": "Detailed description of the issue"
        },
        "status": {
          "type": "string",
          "enum": ["open", "resolved"],
          "description": "Current resolution status"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date ticket was filed"
        }
      },
      "required": ["id", "userId", "userEmail", "subject", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Unique user configuration profile"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "history",
      "description": "Past tool runs generated by specific user"
    },
    "/tickets/{ticketId}": {
      "schema": "tickets",
      "description": "Support tickets submitted to administrators"
    }
  }
}
